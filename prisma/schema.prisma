datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id        String    @id @default(uuid())
  name      String
  email     String    @unique
  avatarUrl String?
  role      String    @default("Member")
  createdAt DateTime  @default(now())
  
  projects  Project[] // Projects owned
  tasks     Task[]    // Tasks assigned
  messages  Message[]
}

model Project {
  id          String   @id @default(uuid())
  key         String   @unique
  name        String
  description String
  ownerId     String
  owner       User     @relation(fields: [ownerId], references: [id])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  tasks       Task[]
  messages    Message[]
}

model Task {
  id          String    @id @default(uuid())
  projectId   String
  project     Project   @relation(fields: [projectId], references: [id])
  title       String
  description String?
  status      String    @default("To Do")
  priority    String    @default("Medium")
  assigneeId  String?
  assignee    User?     @relation(fields: [assigneeId], references: [id])
  startDate   DateTime?
  dueDate     DateTime?
  tags        String    @default("[]")
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model ActivityLog {
  id         String   @id @default(uuid())
  entityType String
  entityId   String
  action     String
  details    String
  userId     String
  timestamp  DateTime @default(now())
}

model Message {
  id        String   @id @default(uuid())
  projectId String
  project   Project  @relation(fields: [projectId], references: [id])
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  content   String
  timestamp DateTime @default(now())
}
