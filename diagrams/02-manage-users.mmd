%%{init: {"sequence": {"mirrorActors": false}}}%%
sequenceDiagram
    actor Admin
    participant UI as Admin Dashboard / People
    participant API as /api/users (Next.js)
    participant SB as Supabase Auth (Admin SDK)
    participant DB as Supabase DB (public.users)
    participant Email as Email Service (lib/email.ts)

    Admin->>UI: Fill Add User Form
    UI->>API: POST /api/users {email, name, role, skills, dob}
    
    rect rgb(240, 240, 255)
    API->>SB: admin_create_user_v2(p_email, p_password, ...)
    
    alt Duplicate Email
        SB-->>API: Error: "duplicate key value..."
        API-->>UI: 400 Bad Request (Email exists)
    else Success
        SB->>SB: Create auth.users record
        SB->>DB: INSERT INTO public.users {...}
        SB-->>API: Result: User UUID
    end
    end
    
    alt Success Flow
        API->>Email: sendInviteEmail(email, p_password)
        Email-->>Admin: "Invitation Sent"
        API-->>UI: 201 Created (User Object)
        UI->>UI: Toast: "User added successfully"
    else Failure
        API-->>UI: 500 Internal Error
        UI->>UI: Toast: "Operation failed"
    end

    Admin->>UI: Update User Profile
    UI->>API: PATCH /api/users/:id {wellness_score, max_workload}
    API->>DB: UPDATE public.users SET ...
    DB-->>API: Rows Affected
    API-->>UI: 200 OK (Updated User)
