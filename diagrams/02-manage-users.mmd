    Admin->>UI: Fill Add User Form
    UI->>API: POST /api/users {fullName, email, password, role, dob, skillExperience, maxWorkload}
    API->>DBLayer: addUser(...)
    
    rect rgb(240, 240, 255)
    DBLayer->>SB: auth.admin.createUser({email, password, email_confirm: true})
    
    alt Duplicate Email
        SB-->>DBLayer: Error: "User already exists"
        DBLayer-->>API: Throw Error
        API-->>UI: 500 / 400 Error Response
    else Success
        SB-->>DBLayer: Created auth user (UUID)
        DBLayer->>DB: INSERT INTO users {id, email, name, role, skills, ...}
        DB-->>DBLayer: Result: User Row
    end
    end
    
